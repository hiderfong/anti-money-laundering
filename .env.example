# ============================================================
# AML System - Production Environment Variables Template
# ============================================================
# Copy this file to .env and fill in production values.
# Do not commit .env. Run scripts/prod-readiness-check.sh before deployment.
#
# Secret generation examples:
#   openssl rand -base64 48   # AML_JWT_SECRET, must remain valid Base64
#   openssl rand -hex 16      # AML_ENCRYPTION_KEY, exactly 32 chars
# ============================================================

# ---- Spring Profile ----
SPRING_PROFILES_ACTIVE=prod
# Optional Spring auto-configuration exclusions for deployments that intentionally
# disable Redis, Elasticsearch, or Neo4j. See docs/deployment/生产部署准备指南.md.
# SPRING_AUTOCONFIGURE_EXCLUDE=

# ---- Deployment ----
# Keep local service ports bound to loopback by default and expose through a reverse proxy.
AML_IMAGE_NAME=aml-system
AML_APP_BIND_ADDR=127.0.0.1
AML_APP_PORT=8080
AML_MYSQL_BIND_ADDR=127.0.0.1
AML_MYSQL_PUBLISHED_PORT=3306
AML_REDIS_BIND_ADDR=127.0.0.1
AML_REDIS_PUBLISHED_PORT=6379
AML_KAFKA_BIND_ADDR=127.0.0.1
AML_KAFKA_PUBLISHED_PORT=9092
AML_ES_BIND_ADDR=127.0.0.1
AML_ES_PUBLISHED_PORT=9200
AML_MINIO_BIND_ADDR=127.0.0.1
AML_MINIO_API_PORT=9000
AML_MINIO_CONSOLE_PORT=9001

# ---- Database ----
AML_DB_HOST=CHANGE_ME_DB_HOST
AML_DB_PORT=3306
AML_DB_NAME=aml_system
AML_DB_USER=CHANGE_ME_DB_USER
AML_DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
# Optional full JDBC URL override:
# AML_DB_URL=jdbc:mysql://CHANGE_ME_DB_HOST:3306/aml_system?useUnicode=true&characterEncoding=UTF-8&useSSL=true&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=false
AML_DB_POOL_MIN_IDLE=10
AML_DB_POOL_MAX_SIZE=50

# ---- Redis ----
AML_REDIS_ENABLED=true
AML_REDIS_HOST=CHANGE_ME_REDIS_HOST
AML_REDIS_PORT=6379
AML_REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
AML_REDIS_DATABASE=0

# ---- Kafka ----
AML_KAFKA_ENABLED=true
AML_KAFKA_BROKERS=CHANGE_ME_KAFKA_1:9092,CHANGE_ME_KAFKA_2:9092
AML_KAFKA_TOPIC=aml-transactions
AML_KAFKA_CONSUMER_GROUP=aml-consumer-group-prod

# ---- Elasticsearch ----
AML_ES_URIS=https://CHANGE_ME_ES_HOST:9200
AML_ES_USERNAME=CHANGE_ME_ES_USER
AML_ES_PASSWORD=CHANGE_ME_ES_PASSWORD

# ---- Neo4j ----
AML_NEO4J_ENABLED=true
AML_NEO4J_URI=bolt://CHANGE_ME_NEO4J_HOST:7687
AML_NEO4J_USERNAME=neo4j
AML_NEO4J_PASSWORD=CHANGE_ME_NEO4J_PASSWORD

# ---- MinIO ----
AML_MINIO_ENDPOINT=https://CHANGE_ME_MINIO_HOST
AML_MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS
AML_MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET
AML_MINIO_BUCKET=aml-documents-prod

# ---- JWT ----
AML_JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_48
AML_JWT_ACCESS_TOKEN_EXPIRE_MS=3600000
AML_JWT_REFRESH_TOKEN_EXPIRE_MS=604800000

# ---- Field Encryption ----
AML_ENCRYPTION_KEY=CHANGE_ME_32_CHAR_AES_KEY_HERE

# ---- CORS ----
# Comma-separated HTTPS origins, no wildcard in production.
AML_CORS_ORIGINS=https://aml.example.com,https://admin.aml.example.com

# ---- Operations ----
AML_API_DOCS_ENABLED=false
AML_LOG_LEVEL_ROOT=WARN
AML_LOG_LEVEL_APP=INFO
AML_SLOW_QUERY_THRESHOLD_MS=500
