# ============================================================
# AML System - Environment Variables Template
# ============================================================
# Copy this file to .env and fill in the values
# .env is in .gitignore and will NOT be committed
#
# Usage:
#   source .env && java -jar aml-system.jar --spring.profiles.active=prod
#   Or use Docker: docker-compose --env-file .env up
# ============================================================

# ---- Database ----
AML_DB_HOST=localhost
AML_DB_PORT=3306
AML_DB_NAME=aml_system
AML_DB_USER=aml_prod
AML_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ---- Redis ----
AML_REDIS_HOST=localhost
AML_REDIS_PORT=6379
AML_REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ---- Kafka ----
AML_KAFKA_BROKERS=localhost:9092

# ---- Elasticsearch ----
AML_ES_HOST=localhost
AML_ES_PORT=9200

# ---- MinIO ----
AML_MINIO_HOST=localhost:9000
AML_MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS
AML_MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET

# ---- JWT ----
# Generate with: openssl rand -base64 48
AML_JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_48

# ---- Encryption ----
# Must be exactly 32 characters for AES-256
AML_ENCRYPTION_KEY=CHANGE_ME_32_CHAR_AES_KEY_HERE

# ---- CORS (comma-separated) ----
AML_CORS_ORIGINS=https://aml.insurance.com,https://admin.aml.insurance.com
